    "On any device, open the link below and enter the code.": {
      "comment": "Sign-in activation screen subtitle (tvOS)",
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意のデバイスで以下のリンクを開き、コードを入力してください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На любом устройстве откройте ссылку ниже и введите код."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在任意设备上打开下面的链接并输入验证码。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En cualquier dispositivo, abre el enlace de abajo e introduce el código."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sur n'importe quel appareil, ouvrez le lien ci-dessous et entrez le code."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne auf einem beliebigen Gerät den folgenden Link und gib den Code ein."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em qualquer dispositivo, abra o link abaixo e insira o código."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Su qualsiasi dispositivo, apri il link qui sotto e inserisci il codice."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Herhangi bir cihazda aşağıdaki bağlantıyı açın ve kodu girin."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Di perangkat mana pun, buka tautan di bawah dan masukkan kode."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 기기에서 아래 링크를 열고 코드를 입력하세요."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी डिवाइस पर नीचे दिया लिंक खोलें और कोड दर्ज करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "على أي جهاز، افتح الرابط أدناه وأدخل الرمز."
          }
        }
      }
    },
    "On this device, tap the button below \u2014 the sign-in page opens with your code already filled in.": {
      "comment": "Sign-in activation screen subtitle (iOS/macOS) \u2014 prompts user to tap the primary link button",
      "extractionState": "manual",
      "localizations": {}
    },
    "Open Activation Page": {
      "comment": "Sign-in primary action button \u2014 opens the activation URL in the browser with code pre-filled",
      "extractionState": "manual",
      "localizations": {}
    },
    "Or scan from another device": {
      "comment": "Sign-in activation screen divider label separating the primary link button from the QR code",
      "extractionState": "manual",
      "localizations": {}
    },
    "Open a channel and tap \"Exclude from SponsorBlock\" to add it here.": {
      "comment": "SponsorBlock excluded-channels empty state description",
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チャンネルを開いて「SponsorBlockから除外」をタップしてここに追加してください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте канал и нажмите «Исключить из SponsorBlock», чтобы добавить его сюда."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开频道并点按“从 SponsorBlock 中排除”以添加到此处。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre un canal y pulsa \"Excluir de SponsorBlock\" para añadirlo aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez une chaîne et appuyez sur \"Exclure de SponsorBlock\" pour l'ajouter ici."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne einen Kanal und tippe auf \"Von SponsorBlock ausschließen\", um ihn hier hinzuzufügen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra um canal e toque em \"Excluir do SponsorBlock\" para adicioná-lo aqui."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri un canale e tocca \"Escludi da SponsorBlock\" per aggiungerlo qui."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir kanal açın ve buraya eklemek için \"SponsorBlock'tan Hariç Tut\" seçeneğine dokunun."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka saluran dan ketuk \"Kecualikan dari SponsorBlock\" untuk menambahkannya di sini."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "채널을 열고 \"SponsorBlock에서 제외\"를 탭하여 여기에 추가하세요."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई चैनल खोलें और यहाँ जोड़ने के लिए \"SponsorBlock से बाहर करें\" टैप करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح قناة واضغط على \"استثناء من SponsorBlock\" لإضافتها هنا."
          }
        }
      }
    },
